# Copy to .env and fill in. The .env file is gitignored — secrets stay local.

# Spotify app — https://developer.spotify.com/dashboard
# Register this exact redirect URI on the app: http://127.0.0.1:8080/auth/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/auth/spotify/callback

# Your Spotify user id (profile -> Share -> Copy link to profile; the id is the last path segment)
OWNER_SPOTIFY_USER_ID=

# Basic auth gating /auth/spotify/login (you choose the password)
AUTH_BASIC_USERNAME=owner
AUTH_BASIC_PASSWORD=

# Local token store
DATABASE_URL=sqlite://music.db

# Optional
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info

# Local dev seam — set to any non-empty value to serve canned Spotify
# fixtures from mock_fixtures/ instead of calling the real API. Skips
# OAuth (a fake token is seeded at startup). /healthz reports
# `mock_mode:true`; every /v1/* response carries `_mock:true` so the
# leptos frontend can render a "MOCK DATA" banner.
# MOCK_DATA=1
